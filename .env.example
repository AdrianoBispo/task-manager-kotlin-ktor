# Environment variables for development environment - these variables will be used when running the application in development mode and will override any default values specified in the application configuration files.
PORT=8080

# Database configuration for development environment - using PostgreSQL with default credentials and a local database named 'task_manager'
POSTGRES_URL=jdbc:postgresql://localhost:5432/task_manager
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# JWT configuration for development environment - use a simple secret for development purposes
JWT_SECRET=task-manager-dev-secret
JWT_ISSUER=task-manager-issuer
JWT_AUDIENCE=task-manager-audience
JWT_REALM=task-manager-realm

# CORS configuration for development environment - allow requests from localhost on common development ports
CORS_ALLOWED_HOSTS='localhost:3000,127.0.0.1:3000,localhost:5173,127.0.0.1:5173,localhost:4200,127.0.0.1:4200'
CORS_ALLOW_CREDENTIALS=true